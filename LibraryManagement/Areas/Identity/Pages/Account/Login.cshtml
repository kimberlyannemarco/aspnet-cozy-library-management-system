@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-gradient-primary text-black text-center py-5">
                    <i class="bi bi-book-fill fs-1 mb-3"></i>
                    <h1 class="mb-2 fw-bold">Library Login</h1>
                    <p class="mb-0 opacity-90">Access your library account</p>
                </div>
                
                <div class="card-body p-5">
                    <!-- Email/Password Form -->
                    <form asp-route-ReturnUrl="@Model.ReturnUrl" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
                        
                        <div class="mb-4">
                            <label asp-for="Input.Email" class="form-label fw-semibold"></label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <input asp-for="Input.Email" class="form-control form-control-lg" placeholder="your.email@example.com" />
                            </div>
                            <span asp-validation-for="Input.Email" class="text-danger small d-block mt-1"></span>
                        </div>
                        
                        <div class="mb-4">
                            <label asp-for="Input.Password" class="form-label fw-semibold"></label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text"><i class="bi bi-lock"></i></span>
                                <input asp-for="Input.Password" class="form-control form-control-lg" placeholder="Enter your password" />
                            </div>
                            <span asp-validation-for="Input.Password" class="text-danger small d-block mt-1"></span>
                        </div>
                        
                        <div class="mb-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div class="form-check">
                                <input class="form-check-input" asp-for="Input.RememberMe" />
                                <label class="form-check-label small" asp-for="Input.RememberMe">
                                    Remember me
                                </label>
                            </div>
                            <a id="forgot-password" asp-page="./ForgotPassword" class="small text-primary fw-semibold text-decoration-none">Forgot your password?</a>
                        </div>
                        
                        <button id="login-submit" type="submit" class="btn btn-primary btn-lg w-100 fw-semibold py-3 shadow-sm mb-4">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                        </button>
                    </form>
                    
                    <!-- Social Login Divider -->
                    @if (Model.ExternalLogins?.Count > 0)
                    {
                        <div class="text-center my-5">
                            <div class="d-flex align-items-center mb-4">
                                <div class="flex-grow-1 border-bottom border-secondary border-2"></div>
                                <span class="px-4 bg-white text-muted fw-semibold fs-6">or</span>
                                <div class="flex-grow-1 border-bottom border-secondary border-2"></div>
                            </div>
                            <h6 class="text-muted mb-4 fw-semibold">Continue with a social account</h6>
                            
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                <form asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="mb-3">
                                    <button type="submit"
                                            class="btn btn-primary"
                                            name="provider"
                                            value="@provider.Name"
                                            title="Log in using your @provider.DisplayName account"
                                            style="background-color: #8b5e3c; border-color: #8b5e3c; color: white;">
                                        @provider.DisplayName
                                    </button>
                                </form>
                            }

                        </div>
                    }
                    
                    <!-- Register Link -->
                    <div class="text-center pt-4 border-top">
                        <small class="text-muted">
                            Don't have an account? 
                            <a asp-page="./Register" class="text-primary fw-semibold text-decoration-none">Create one now</a>
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
