@model LibraryManagement.Models.Book

<h1>Edit <i>@Model.Title</i> Details</h1>

<form asp-action="Edit" method="post">
    <input asp-for="BookId" type="hidden" />
    
    <div class="form-group">
        <label>Title:</label>
        <input asp-for="Title" class="form-control" />
    </div>
    
    <div class="form-group">
        <label>ISBN:</label>
        <input asp-for="ISBN" class="form-control" />
    </div>
    
    <div class="form-group">
        <label>Publication Year:</label>
        <input asp-for="PublicationYear" class="form-control" />
    </div>
    <br>
    <button type="submit" class="btn btn-primary">Save Changes</button> <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>


