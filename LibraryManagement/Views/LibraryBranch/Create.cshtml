@model LibraryManagement.Models.LibraryBranch

<h1>Add New Branch</h1>

<form asp-action="Create" method="post">
    <input asp-for="LibraryBranchId" type="hidden" />
    
    <div class="form-group">
        <label asp-for="BranchName">Branch Name:</label>
        <input asp-for="BranchName" class="form-control" />
        <span asp-validation-for="BranchName" class="text-danger"></span>
    </div>
    
    <div class="form-group">
        <label asp-for="BranchAddress">Branch Address:</label>
        <input asp-for="BranchAddress" class="form-control" />
        <span asp-validation-for="BranchAddress" class="text-danger"></span>
    </div>
    
    <br>
    <button type="submit" class="btn btn-primary">Save Changes</button> <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

