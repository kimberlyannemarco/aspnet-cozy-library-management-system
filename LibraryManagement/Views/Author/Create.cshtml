@model LibraryManagement.Models.Author

<h1>Add New Author</h1>

<form asp-action="Create" method="post">
    <input asp-for="AuthorId" type="hidden" />
    
    <div class="form-group">
        <label asp-for="FirstName">First Name:</label>
        <input asp-for="FirstName" class="form-control" />
        <span asp-validation-for="FirstName" class="text-danger"></span>
    </div>
    
    <div class="form-group">
        <label asp-for="LastName">Last Name:</label>
        <input asp-for="LastName" class="form-control" />
        <span asp-validation-for="LastName" class="text-danger"></span>
    </div>
    
    <div class="form-group">
        <label asp-for="BirthYear">Birth Year:</label>
        <input asp-for="BirthYear" class="form-control" />
        <span asp-validation-for="BirthYear" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="BooksPublished">No. of Published Books:</label>
        <input asp-for="BooksPublished" class="form-control" />
        <span asp-validation-for="BooksPublished" class="text-danger"></span>
    </div>
    
    <br>
    <button type="submit" class="btn btn-primary">Save Changes</button> <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

