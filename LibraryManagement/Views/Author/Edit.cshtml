@model LibraryManagement.Models.Author

<h1>Edit <i>@Model.FirstName @Model.LastName</i> Details</h1>
<form asp-action="Edit" method="post">
    <input asp-for="AuthorId" type="hidden" />
    
    <div class="form-group">
        <label>First Name:</label>
        <input asp-for="FirstName" class="form-control" />
    </div>
    
    <div class="form-group">
        <label>Last Name:</label>
        <input asp-for="LastName" class="form-control" />
    </div>
    
    <div class="form-group">
        <label>Birth Year:</label>
        <input asp-for="BirthYear" class="form-control" />
    </div>

    <div class="form-group">
        <label>No. of Published Books:</label>
        <input asp-for="BooksPublished" class="form-control" />
    </div>
    <br>
    <button type="submit" class="btn btn-primary">Save Changes</button> <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>


